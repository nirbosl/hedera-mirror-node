          "datasource": {
            "uid": "${prometheus}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (namespace, scenario, url) (rate(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\"}[$__rate_interval])))",
          "interval": "1m",
          "legendFormat": "{{namespace}} {{scenario}} {{url}}",
