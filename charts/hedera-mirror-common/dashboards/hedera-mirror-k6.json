      "targets": [
        {
          "datasource": {
            "uid": "${prometheus}"
          },
          "editorMode": "code",
          "expr": "sum by (namespace, scenario, url) (histogram_sum(rate(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\"}[$__rate_interval]))) / sum by (namespace, scenario, url) (histogram_count(rate(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\"}[$__rate_interval])))",
          "interval": "1m",
          "legendFormat": "{{namespace}} {{scenario}} {{url}}",
