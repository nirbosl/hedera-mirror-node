          "editorMode": "code",
          "expr": "sum by (namespace, scenario, url) (histogram_count(rate(k6_requests_seconds{namespace=~\"$namespace\",scenario=~\"$scenario\"}[$__rate_interval])))",
          "interval": "1m",
          "legendFormat": "{{namespace}} {{scenario}} {{url}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Requests per Second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "description": "Average request duration per scenario",
